{
  "name": "apiaddicts-asyncapi-style-guide-spectral",
  "version": "1.0.0",
  "description": "Spectral ruleset for AsyncAPI definitions by APIAddicts / ApiQuality",
  "main": "asa-spectral.yaml",
  "files": [
    "asa-spectral.yaml",
    "functions/"
  ],
  "scripts": {
    "test": "jest --coverage --detectOpenHandles --no-cache --forceExit",
    "make-badges": "coverage-badges",
    "lint:example": "spectral lint -r asa-spectral.yaml test/fixtures/valid-asyncapi2.yaml"
  },
  "keywords": [
    "spectral",
    "linter",
    "asyncapi",
    "asyncapi2",
    "asyncapi3",
    "apiaddicts",
    "apiquality"
  ],
  "author": {
    "name": "APIQuality"
  },
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/apiaddicts/apiaddicts-asyncapi-style-guide-spectral"
  },
  "devDependencies": {
    "@stoplight/spectral-core": "^1.19.5",
    "@stoplight/spectral-functions": "^1.9.0",
    "@stoplight/spectral-ruleset-migrator": "^1.10.0",
    "@stoplight/spectral-rulesets": "^1.20.2",
    "@types/jest": "^29.5.14",
    "coverage-badges-cli": "^2.1.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "functions/*.js"
    ],
    "coverageThreshold": {
      "./functions/*.js": {
        "statements": 0
      }
    },
    "coverageReporters": [
      "lcov",
      "json-summary"
    ]
  }
}
